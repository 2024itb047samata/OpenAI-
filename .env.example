# Google Gemini API Key - Retrieve from Google AI Studio and set in Settings > Secrets
GEMINI_API_KEY=

# Application environment (development or production)
NODE_ENV=

# GitHub OAuth App Configuration - Register at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# FastAPI Configuration
FASTAPI_SECRET_KEY=             # Key for session cookie signing
ENCRYPTION_KEY=                 # 32-byte url-safe base64 key for encrypting access tokens
DATABASE_URL=sqlite:///./fastapi_oauth.db

